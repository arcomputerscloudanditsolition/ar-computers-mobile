      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-document-picker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "301ddf6a-85e1-42b0-8bee-eb5b13263d5c"
      }
    }
  }
}
